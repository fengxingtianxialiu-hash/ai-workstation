{
  "name": "ai-workstation",
  "entry": "./proxy/worker.js",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "assets": {
    "directory": "./dist",
    "notFoundStrategy": "singlePageApplication"
  },
  "routes": [
    {
      "path": "/proxy/*",
      "function": "./proxy/worker.js"
    },
    {
      "path": "/search/*",
      "function": "./proxy/worker.js"
    },
    {
      "path": "/image-gen/*",
      "function": "./proxy/worker.js"
    }
  ]
}
